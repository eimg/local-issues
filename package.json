{
  "name": "acme-issues",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Experimental local issue and pull-request manager for Helix",
  "license": "MIT",
  "author": "Ei Maung",
  "keywords": [
    "issues",
    "tracker",
    "webhooks",
    "helix",
    "local",
    "experimental"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eimg/acme-issues.git"
  },
  "bugs": {
    "url": "https://github.com/eimg/acme-issues/issues"
  },
  "homepage": "https://github.com/eimg/acme-issues#readme",
  "engines": {
    "node": ">=20.19"
  },
  "bin": {
    "acme-issues": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && tsc -p web/tsconfig.json && vite build && cp -r src/public dist/",
    "build:web": "vite build",
    "dev:web": "vite --host 127.0.0.1",
    "typecheck:web": "tsc -p web/tsconfig.json",
    "dev": "npm run build:web && tsx src/cli.ts serve",
    "start": "node dist/cli.js",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.4",
    "better-sqlite3": "^11.10.0",
    "express": "^5.2.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.4",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^8.1.5"
  }
}
